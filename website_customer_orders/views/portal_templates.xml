<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="portal_customer_orders_template" name="My Orders">
            <t t-call="portal.portal_layout">
                <t t-set="breadcrumbs_searchbar" t-value="True"/>

                <t t-call="portal.portal_searchbar">
                    <t t-set="title">My Orders</t>
                </t>

<!--                <div class="o_portal_frontend_tools row no-gutters">-->
<!--                    <t t-call="portal.portal_pager"/>-->
<!--                </div>-->

                <div class="row">
                    <div class="col-12">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Order Number</th>
                                    <th>Order Date</th>
                                    <th>Confirmation Date</th>
                                    <th>Customer Order Ref</th>
                                    <th>Salesperson</th>
                                    <th>Position No</th>
                                    <th>Product Code</th>
                                    <th>Description</th>
                                    <th>Ordered Quantity</th>
                                    <th>Delivered Quantity</th>
                                    <th>Remaining Quantity</th>
                                    <th>Departure Date</th>
                                    <th>Estimated Delivery Date</th>
                                    <th>PO Number</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="orders_data">
                                    <t t-foreach="orders_data" t-as="order_line">
                                        <tr>
                                            <td><span t-field="order_line.x_order_number"/></td>
                                            <td><span t-field="order_line.x_date_order"/></td>
                                            <td><span t-field="order_line.x_confirmation_date"/></td>
                                            <td><span t-field="order_line.x_musteri_sip_no"/></td>
                                            <td><span t-field="order_line.x_temsilci.name"/></td>
                                            <td><span t-field="order_line.x_poz_no"/></td>
                                            <td><span t-field="order_line.x_default_code"/></td>
                                            <td><span t-field="order_line.x_aciklama"/></td>
                                            <td><span t-field="order_line.x_product_uom_qty"/></td>
                                            <td><span t-field="order_line.x_teslim_edilen"/></td>
                                            <td><span t-field="order_line.x_kalan_miktar"/></td>
                                            <td><span t-field="order_line.x_yola_cikis_tarihi"/></td>
                                            <td><span t-field="order_line.x_ongprulen_teslim_tarihi"/></td>
                                            <td><span t-field="order_line.x_po_number"/></td>
                                        </tr>
                                    </t>
                                </t>
                                <t t-else="">
                                    <tr>
                                        <td colspan="14" class="text-center">No orders found.</td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
        </template>

        <template id="portal_customer_orders_menu" inherit_id="portal.portal_my_home">
             <xpath expr="//ul[hasclass('o_portal_docs')]" position="inside">
                <li t-if="user_id.partner_id" class="list-group-item">
                    <a href="/customer/orders">My Orders</a>
                </li>
            </xpath>
        </template>
    </data>
</odoo>