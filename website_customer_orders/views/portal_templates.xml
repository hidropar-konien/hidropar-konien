<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_customer_orders_template" name="My Orders">
        <t t-call="portal.portal_layout">
<!--            <t t-set="breadcrumbs_searchbar" t-value="True"/>-->

            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Orders</t>
            </t>

            <!--                <div class="o_portal_frontend_tools row no-gutters">-->
            <!--                    <t t-call="portal.portal_pager"/>-->
            <!--                </div>-->

            <div class="row">
                <div class="col-12">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Order Number</th>
                                <th>Order Date</th>
                                <th>Confirmation Date</th>
                                <th>Müşteri Sipariş No</th>
                                <th>Temsilci</th>
                                <th>Position No</th>
                                <th>Product Code</th>
                                <th>Açıklama</th>
                                <th>Ordered Quantity</th>
                                <th>Teslim Edilen Miktar</th>
                                <th>Kalan Miktar</th>
                                <th>Yola Çıkış Tarihi</th>
                                <th>Ön Görülen Teslim Tarihi</th>
                                <th>PO Number</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="orders_data">
                                <t t-foreach="orders_data" t-as="order_line">
                                    <tr>
                                        <td>
                                            <span t-esc="order_line.get('order_number')"/>
                                        </td>
                                        <td>
    <span t-esc="order_line.get('date_order')"/> <!-- Bu t-options t-esc ile çalışmayabilir, t-field gerektirir. Alternatif: -->                                        </td>
                                        <td>
                                            <span t-esc="order_line.get('confirmation_date')"/>
                                        </td>
                                        <td>
                                            <span t-esc="order_line.get('musteri_sip_no')"/>
                                        </td>
                                        <td>
                                            <span t-esc="order_line.get('temsilci')"/>
                                        </td>
                                            <td>
                                                <span t-field="order_line.poz_no"/>
                                            </td>
                                        <td>
                                            <span t-esc="order_line.get('default_code')"/>
                                        </td>
                                        <td>
                                            <span t-esc="order_line.get('aciklama')"/>
                                        </td>
                                        <td>
                                            <span t-esc="order_line.get('product_uom_qty')"/>
                                        </td>
                                        <td>
                                            <span t-esc="order_line.get('teslim_edilen')"/>
                                        </td>
                                        <td>
                                            <span t-esc="order_line.get('kalan_miktar')"/>
                                        </td>
                                        <td>
                                            <span t-esc="order_line.get('yola_cikis_tarihi')"/>
                                        </td>
                                        <td>
                                            <span t-esc="order_line.get('ongorulen_teslim_tarihi')"/>
                                        </td>
                                        <td>
                                            <span t-esc="order_line.get('po_number')"/>
                                        </td>
                                    </tr>
                                </t>
                            </t>
<!--                            <t t-else="">-->
<!--                                <tr>-->
<!--                                    <td colspan="14" class="text-center">No orders found.</td>-->
<!--                                </tr>-->
<!--                            </t>-->
                        </tbody>
                    </table>
                </div>
                <div t-if="pager" class="o_portal_pager text-center">
              <t t-call="portal.pager"/>
            </div>
            </div>
        </t>
    </template>

    <template id="portal_customer_orders_menu" inherit_id="portal.portal_my_home">
        <xpath expr="//ul[hasclass('o_portal_docs')]" position="inside">
            <li t-if="user_id.partner_id" class="list-group-item">
                <a href="/customer/orders">My Orders</a>
            </li>
        </xpath>
    </template>
</odoo>