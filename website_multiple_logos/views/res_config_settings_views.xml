<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_website_multiple_logos" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.website.multiple.logos</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='website_info']" position="inside">
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_left_pane"/>
                    <div class="o_setting_right_pane">
                        <span class="o_form_label">Header Logos</span>
                        <div class="text-muted">
                            Manage multiple logos to display in the website header.
                        </div>
                        <div class="mt16">
                            <field name="header_logo_ids" nolabel="1"/>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
