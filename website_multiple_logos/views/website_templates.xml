<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Asset registration: This ensures CSS and JS are loaded on the frontend -->
    <template id="assets_frontend_sticky_header" name="Sticky Header Assets" inherit_id="website.assets_frontend">
        <xpath expr="." position="inside">
            <link rel="stylesheet" type="text/css" href="/website_multiple_logos/static/src/css/website_multiple_logos.css"/>
            <script type="text/javascript" src="/website_multiple_logos/static/src/js/website_multiple_logos.js"></script>
        </xpath>
    </template>

    <!-- Template to replace the default logo with multiple logos -->
    <template id="layout_multiple_logos" inherit_id="website.layout_logo_show" name="Show Multiple Logos">
        <xpath expr="//header//a[hasclass('navbar-brand')]" position="replace">
            <!-- If custom logos are defined, loop through them -->
            <t t-if="website and website.header_logo_ids">
                <div class="d-flex align-items-center">
                    <t t-foreach="website.header_logo_ids.filtered(lambda l: l.active)" t-as="header_logo">
                        <a t-att-href="header_logo.url or '/'" class="navbar-brand-logo" t-att-target="'_blank' if header_logo.url and not header_logo.url.startswith('/') else None">
                            <img t-attf-src="/web/image/website.header.logo/#{header_logo.id}/logo"
                                 style="max-height: 45px; margin: 0 8px; vertical-align: middle;"/>
                        </a>
                    </t>
                </div>
            </t>
            <t t-else="">
                <!-- Otherwise, fallback to the default company logo -->
                <a href="/" class="navbar-brand logo">
                    <span t-field="res_company.logo" t-options="{'widget': 'image'}" t-att-alt="'Logo of %s' % res_company.name" t-att-title="res_company.name" />
                </a>
            </t>
        </xpath>
    </template>
</odoo>
